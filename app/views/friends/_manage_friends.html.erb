<div class="canvas gray100-canvas embossed p-1 mb-2 col-12 col-md-6">
  <h2 class="fs-fluid-6 fst-italic fw-bolder ps-2">Manage Friends</h2>
  <div class="canvas gray100-canvas embossed my-2 pt-1">
    <h2 class="fs-fluid-7 fst-italic ps-1">Add Friends</h2>
    <form data-action="friends#add">
      <div class="input-group input-group-sm mb-1">
        <input type="text" data-friends-target="input" placeholder="Sebastian Coe">
        <button type="submit" class="btn btn-primary btn-sm p-1"><i class="bi bi-plus-lg"></i></button>
      </div>   
    </form>     
  </div>
  <div data-friends-target="selectedFriends" class="canvas gray100-canvas embossed my-2 pt-1">
  </div>
</div>

