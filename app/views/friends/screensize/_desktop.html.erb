<% data_action = 'friends#sort' %>
<div class="d-none d-xl-block">
  <table class="table runs-table">
    <thead class="runs-thead">
      <tr>
      <th></th>
      <th class="sortable"><%= sortable(column: 'name', sort_column: @sort_option, sort_direction: @sort_direction, data_action:) %></th>
      <th>Venue</th>
      <th>Date</th>
      <th>Local</th>
      <th>Group</th>
      <th class="sortable"><%= sortable(column: 'runs', coltitle: 'Count', sort_column: @sort_option, sort_direction: @sort_direction, data_action:) %></th>
      <th class="sortable"><%= sortable(column: 'agegrade', coltitle: 'Grade', sort_column: @sort_option, sort_direction: @sort_direction, data_action:)  %></th>
      <th class="sortable"><%= sortable(column: 'time', sort_column: @sort_option, sort_direction: @sort_direction, data_action:) %></th>
      </tr>
    </thead>

    <tbody>
      <%= render partial: "friends/screensize/row", collection: runs, as: :run %>
    </tbody>
  </table>
</div>