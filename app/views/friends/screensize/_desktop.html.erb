<div class="d-none d-xl-block">
  <table class="table runs-table">
    <thead class="runs-thead">
      <tr>
      <th></th>
      <th class="sortable"><%= sortable(column: 'name', **@sortable_options) %></th>
      <th>Venue</th>
      <th>Date</th>
      <th>Local</th>
      <th>Group</th>
      <th class="sortable"><%= sortable(column: 'runs', coltitle: 'Count', **@sortable_options) %></th>
      <th class="sortable"><%= sortable(column: 'agegrade', coltitle: 'Grade', **@sortable_options)  %></th>
      <th class="sortable"><%= sortable(column: 'time', **@sortable_options) %></th>
      </tr>
    </thead>

    <tbody>
      <%= render partial: "friends/screensize/row", collection: runs, as: :run %>
    </tbody>
  </table>
</div>