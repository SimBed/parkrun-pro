<tr>
  <td>
    <span class="badge rounded-pill bg-primary-subtle text-primary-emphasis">
      <%= number_with_delimiter(run_counter + 1) %>
    </span>
  </td>
  <td class="runs-name">
    <%= run.anonymized_name %></td>
  <td class="runs-local"><%= run.parkrun %></td>
  <td class="runs-local"><%= run.date.strftime('%d %b %Y') %></td>
  <td class="runs-local"><%= run.position %></td>
  <td class="runs-agegroup"><%= run.agegroup %></td>
  <td class="runs-local"><%= run.runs %></td>
  <td class="runs-agegrade"><%= number_to_percentage(run.agegrade, precision: 1) %></td>
  <td class="runs-time"><%= min_sec_format(run.time) %></td>
</tr>