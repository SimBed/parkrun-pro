<% content_for :title, "Venues for latest results" %>

<div class="container my-4">
    <h1 class="h4 mb-0">Venues <small> <%="(#{@venues.size})"%> </small></h1>
    <p class="text-muted mb-0 small">for latest results</p>

    <% @venues.each do |venue| %>
      <div><%= venue %></div>
    <% end %>
</div>
