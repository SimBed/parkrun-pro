<div class="d-none d-xl-block">
  <table class="table runs-table">
    <thead class="runs-thead">
      <tr>
        <th></th>
        <th>Name</th>
        <th>Venue</th>
        <!--th>Local</th-->
        <th>Gender</th>
        <th>Group</th>
        <th class="sortable"><%= sortable(column: 'runs', coltitle: 'Count', **@sortable_options) %></th>
        <th class="sortable"><%= sortable(column: 'agegrade', coltitle: 'Grade', **@sortable_options) %></th>
        <th class="sortable"><%= sortable(column: 'time', coltitle: 'Time', **@sortable_options) %></th>
      </tr>
    </thead>
    <tbody>
      <%= render partial: "runs/screensize/row", collection: @runs, as: :run %>
    </tbody>
  </table>
</div>