<div class="container my-4">
  <div class="">
    <h1 class="h4 mb-0">UK Parkruns</h1>
    <h2 class="h5 mb-0">Results</h1>
  </div>
  <%= render 'filter_form' %>
  <div>
    <%= line_chart @line_chart_data %>
  </div>
  <div>
    <%= column_chart @pie_chart_data.group(:agegroup).count %>
  </div>
  <%= render 'stats_summary' %>
  <%== @pagy.series_nav(:bootstrap) %>

  <%= form_with url: runs_path, method: :get, class: "form-class" do %>
    <%= label_tag :time, "Jump to time (mm:ss or h:mm:ss)" %>
    <%= text_field_tag :time, params[:time] %>
    <%= submit_tag "Go" %>
  <% end %>

  <div class="card shadow-sm border-0">
    <div class="card-body p-0">
      <div class="d-none d-md-grid px-2 py-2 border-bottom text-muted small fw-semibold"
           style="grid-template-columns: 100px 240px 240px 80px 80px 80px 80px 80px 80px;">
        <div>Position</div>
        <div>Name</div>
        <div>Parkrun</div>
        <div>Local</div>
        <div>Gender</div>
        <div>Group</div>
        <div>Count</div>
        <div>Grade</div>
        <div class="text-end">Time</div>
      </div>

      <div class="list-group list-group-flush">
        <% @runs.each_with_index do |run, index| %>
          <div class="list-group-item py-1 border-0 border-bottom">

            <%#= render partial: 'mobile', locals: {run:, index:}%>
            <%#= render partial: 'desktop', locals: {run:, index:}%>

            <%# MOBILE %>
            <div class="d-flex d-md-none flex-column gap-1">
              <div class="d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-2">
                  <div class="badge bg-primary-subtle text-primary-emphasis rounded-pill py-1 fw-semibold">
                    <%= number_with_delimiter(@pagy.offset + index + 1) %>
                  </div>
                  <div class="fw-semibold text-body">
                    <%= run.anonymized_name %>
                  </div>
                </div>
                <div class="fw-semibold">
                  <%= min_sec_format(run.time) %>
                </div>
              </div>
              <div class="text-muted small">
                <span><%= run.parkrun %></span>
                <span class="mx-1">•</span>
                <span><%= run.agegroup %></span>
                <span class="mx-1">•</span>
                <span><%= number_to_percentage(run.agegrade, precision: 1) %></span>
              </div>
            </div>

            <%# DESKTOP %>
            <div class="d-none d-md-grid text-muted small align-items-center"
                  style="grid-template-columns: 100px 240px 240px 80px 80px 80px 80px 80px 80px;">
              <div class="d-flex align-items-center">
                <div class="badge bg-primary-subtle text-primary-emphasis rounded-pill px-2 py-1 fw-semibold">
                  <%= number_with_delimiter(@pagy.offset + index + 1) %>
                </div>
              </div>
              <div class="fw-semibold text-body">
                <%= run.anonymized_name %>
              </div>
              <div>
                <%= run.parkrun %>
              </div>
              <div>
                <%= run.position %>
              </div>
              <div>
                <%= run.gender %>
              </div>
              <div>
                <%= run.agegroup %>
              </div>
              <div>
                <%= run.runs %>
              </div>
              <div>
                <%= number_to_percentage(run.agegrade, precision: 1) %>
              </div>
              <div class="text-end">
                <%= min_sec_format(run.time) %>
              </div>
            </div>

          </div>
        <% end %>
      </div>

      <% if @runs.blank? %>
        <div class="px-3 py-4 text-center text-muted">
          No runs to display yet.
        </div>
      <% end %>
    </div>
  </div>
</div>
