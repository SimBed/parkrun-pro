<div class="d-flex d-md-none flex-column gap-1">
  <div class="d-flex justify-content-between align-items-center">
    <div class="d-flex align-items-center gap-2">
      <div class="badge bg-primary-subtle text-primary-emphasis rounded-pill px-3 py-2 fw-semibold">
        <%= number_with_delimiter(@pagy.offset + index + 1) %>
      </div>
      <div class="fw-semibold text-body">
        <%= run.name %>
      </div>
    </div>
    <div class="fw-semibold">
      <%= min_sec_format(run.time) %>
    </div>
  </div>
  <div class="text-muted small">
    <span><%= run.parkrun %></span>
    <span class="mx-1">•</span>
    <span><%= run.agegroup %></span>
    <span class="mx-1">•</span>
    <span><%= number_to_percentage(run.agegrade, precision: 1) %></span>
  </div>
</div>

