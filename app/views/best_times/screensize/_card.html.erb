<div class="list-group-item py-2 border-0 border-bottom">

  <div class="d-flex justify-content-between align-items-center">
    <div class="d-flex align-items-center gap-2">
      <span class="badge rounded-pill py-1 fw-semibold">
        <%= number_with_delimiter(run_counter + 1) %>
      </span>
      <span class="runs-name">
        <%= run.anonymized_name %>
      </span>
      <span class="runs-time">
        <%= min_sec_format(run.time) %>
      </span>
    </div>
  </div>

  <div class="text-muted small">
    <span class="runs-venue"><%= run.venue %></span>
    <span class="mx-1">•</span>
    <span><%= run.date.strftime('%d %b %Y') %></span>
    <span class="mx-1">•</span>    
    <span class="runs-agegroup"><%= run.agegroup %></span>
    <span class="mx-1">•</span>
    <span class="runs-agegrade"><%= number_to_percentage(run.agegrade, precision: 1) %></span>    
  </div>

</div>