<% venue_stats_sort_option = session[:venue_stats_sort_option]%>
<form action="/venue_stats" method="GET">
  <div class="mt-0 mb-0">
    <i class="bi bi-sort-alpha-down"></i>
    <select class="form-control-sm sort" name="venue_stats_sort_option" onchange="this.form.requestSubmit()">
      <option disabled="disabled" selected="selected" value="">Sort by</option>
      <option value="parkrun" <%="selected" if venue_stats_sort_option == "parkrun"%> >name</option>
      <option value="count" <%="selected" if venue_stats_sort_option == "count"%> >count</option>
      <option value="fastest" <%="selected" if venue_stats_sort_option == "fastest"%> >fastest</option>
      <option value="median" <%="selected" if venue_stats_sort_option == "median"%> >median</option>
      <option value="mean" <%="selected" if venue_stats_sort_option == "mean"%> >mean</option>
      <option value="slowest" <%="selected" if venue_stats_sort_option == "slowest"%> >slowest</option>
      <option value="avg_age" <%="selected" if venue_stats_sort_option == "avg_age"%> >average age</option>
    </select>
  </div>
</form>