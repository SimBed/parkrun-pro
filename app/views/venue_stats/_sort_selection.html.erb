<form action="/venue_stats" method="GET", class="d-flex d-xl-none align-items-center">
  <i class="bi bi-sort-alpha-down fs-6"></i>
  <select class="form-control-sm sort" name="sort_option" onchange="this.form.requestSubmit()">
    <option disabled="disabled" selected="selected" value="">Sort by</option>
    <% [['parkrun', 'name'], ['count', 'count'], ['fastest', 'fastest'], ['median', 'median'],
        ['slowest', 'slowest'], ['avg_age', 'average age']].each do |value, label| %>
      <option value="<%= value %>" <%="selected" if @sort_option == value%> ><%= label %></option>
    <% end %>
  </select>

  <button name="sort_direction" value="<%= @next_direction %>" class="btn btn-sort-direction btn-primary">
    <span class="arrow-default">
      <%= @sort_direction == "asc" ? "↑" : "↓" %>
    </span>

    <span class="arrow-hover">
      <%= @next_direction == "asc" ? "↑" : "↓" %>
    </span>    
  </button>
</form>